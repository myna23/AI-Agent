# ============================================================
# Zambia GeoHub AI Platform — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to version control.
# ============================================================

# Required — get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY_HERE

# Optional — max GeoJSON features to pull per dataset query (default 200)
MAX_FEATURES=200

# Optional — ArcGIS Hub base URL (default shown)
HUB_BASE_URL=https://zmb-geowb.hub.arcgis.com
